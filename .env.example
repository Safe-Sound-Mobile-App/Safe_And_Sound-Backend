# Server Configuration
PORT=3000
NODE_ENV=development

# Firebase Admin SDK — path to your service account JSON
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIAL_PATH=./firebase/your-service-account.json

# Python executable that has tensorflow, numpy, joblib installed
# Use the venv from your ML project, e.g.:
# PYTHON_PATH=/Users/yourname/PycharmProjects/SafeAndSoundPrototype/.venv/bin/python3
PYTHON_PATH=/usr/bin/python3
